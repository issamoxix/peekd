{
  "name": "sentinel-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:analyzer\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:analyzer": "npm run dev --workspace=analyzer",
    "build": "npm run build --workspace=shared && npm run build --workspace=analyzer && npm run build --workspace=frontend",
    "start": "npm run start --workspace=analyzer",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "backend/shared",
    "backend/analyzer",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
