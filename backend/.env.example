# Peec AI API Configuration
# Generate from app.peec.ai → Settings → API Keys
PEECAI_API_KEY=your_peec_api_key_here

# Anthropic API Configuration (used by the threat engine for Claude analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=sqlite:///./sentinel.db

# Security
SECRET_KEY=your_random_secret_key_here_change_in_production

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Email Alert Configuration
ALERT_EMAIL_FROM=sentinel@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
